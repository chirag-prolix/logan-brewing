<div class="age-page">
    <div class="age-card">
        <div class="age-content-card">
            
            <div class="crown">
                <img src="{{ 'crown.png' | asset_url }}" alt="">
            </div>
            
                <div class="age-input-block">
                <h1>Are you old enough to sink piss at the pub?</h1>
                <div class="subtitle">Enter the year you were born</div>
                <div class="year-boxes">
                    <input type="text" maxlength="1" class="year-digit" placeholder="0">
                    <input type="text" maxlength="1" class="year-digit" placeholder="0">
                    <input type="text" maxlength="1" class="year-digit" placeholder="0">
                    <input type="text" maxlength="1" class="year-digit" placeholder="0">
                </div>

                <div class="error">You must be 18+ to enter.</div>

                <div class="remember">
                    <label> <input type="radio" checked name="remember" id="rememberAge"> Remember my details </label>
                </div>

                <div class="legal">
                    By submitting this form, you agree to 
                    <a href="/pages/legal-stuff" target="_blank">Legal Stuff</a> 
                    and 
                    <a href="/policies/privacy-policy" target="_blank">Privacy Policy</a> 
                    of the Logan Brewing website.
                </div>
            </div>
            <div class="age-child-warning">
                <h1>Sorry little tacker</h1>
                <div class="subtitle">This site is for legends 18+ only. Back to the Nintendo 64'</div>

                <div class="error">You must be 18+ to enter.</div>

                <button class="secondary-btn try-again-btn">try again</button>
                <div class="legal">
                    By submitting this form, you agree to 
                    <a href="/pages/legal-stuff" target="_blank">Legal Stuff</a> 
                    and 
                    <a href="/policies/privacy-policy" target="_blank">Privacy Policy</a> 
                    of the Logan Brewing website.
                </div>
            </div>

        </div>
    </div>
    <div class="age-img-bottom-text">
        *Reference image*<br>
        *not licensed*
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function(){
  const digits = document.querySelectorAll(".year-digit");
  const error = document.querySelector(".error");
  const remember = document.getElementById("rememberAge");

  const ageBlock = document.querySelector(".age-input-block");
  const childBlock = document.querySelector(".age-child-warning");
  const tryAgainBtn = document.querySelector(".try-again-btn");

  digits.forEach((digit, index)=>{
    digit.addEventListener("input",(e)=>{
      e.target.value = e.target.value.replace(/[^0-9]/g,'');
      if(e.target.value && index < digits.length-1){
        digits[index+1].focus();
      }
    });

    digit.addEventListener("keydown",(e)=>{
      if(e.key==="Backspace" && !digit.value && index>0){
        digits[index-1].focus();
      }
    });
  });

  digits[3].addEventListener("input", function(){

    let year="";
    digits.forEach(d=>year+=d.value);

    if(year.length===4){
      const age = new Date().getFullYear() - parseInt(year);

      if(age >= 18){

        localStorage.setItem("ageVerified","true");
        window.location.href="/";

      } else {

        // Under 18 → show warning screen
        ageBlock.style.display = "none";
        childBlock.style.display = "block";

      }
    }
  });

  // Try again button logic
  tryAgainBtn.addEventListener("click", function(){

    // Clear inputs
    digits.forEach(d => d.value = "");

    // Switch back to input screen
    ageBlock.style.display = "block";
    childBlock.style.display = "none";

    // Focus first input
    digits[0].focus();
  });

});
</script>