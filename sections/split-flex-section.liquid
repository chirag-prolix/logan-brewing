<section class="split-flex-section">
  {% for block in section.blocks %}
    <div class="split-row {% if block.settings.reverse %}reverse{% endif %}">

      <div class="split-image">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url}}" alt="">
        {% endif %}
      </div>

      <div class="split-content">
        {% if block.settings.show_cross %}
          <div class="cross-icons">
            {% for i in (1..block.settings.cross_count) %}
              <span class="cross-icon"><img src="{{ 'cross-red.svg' | asset_url }}" alt=""></span>
            {% endfor %}
          </div>
        {% endif %}

        {% if block.settings.desc_image != blank %}
          <div class="desc-image">
            <a href="{{ block.settings.button_link }}">
              <img src="{{ block.settings.desc_image | image_url}}" alt="">
            </a>
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <a href="{{ block.settings.button_link }}">
            <h2>{{ block.settings.heading }}</h2>
          </a>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="description">
            {{ block.settings.text }}
          </div>
        {% endif %}

        <a href="{{ block.settings.button_link }}" class="btn {{ block.settings.button_class }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Split Flex Section",
  "blocks": [
    {
      "type": "content_block",
      "name": "Content Block",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_cross",
          "label": "Show Cross Icons",
          "default": true
        },
        {
          "type": "range",
          "id": "cross_count",
          "label": "Number of Cross Icons",
          "min": 1,
          "max": 6,
          "step": 1,
          "default": 3
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "desc_image",
          "label": "Image Below Description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "button_class",
          "label": "Button CSS Class",
          "info": "Example: primary-btn or btn btn--secondary"
        },
        {
          "type": "checkbox",
          "id": "reverse",
          "label": "Swap Image & Content (Left/Right)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split Flex Section"
    }
  ]
}
{% endschema %}