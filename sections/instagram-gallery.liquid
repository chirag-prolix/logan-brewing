<section class="insta-gallery">
  <div class="page-width">
    
    {% if section.settings.heading != blank %}
      <h2 class="insta-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="insta-text">{{ section.settings.text }}</div>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" target="_blank" class="secondary-btn">
        {{ section.settings.button_text }}
      </a>
    {% endif %}

    <div class="swiper instaSwiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide">
            <div class="insta-item">
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}">
              {% endif %}
              
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url }}" alt="" >
              {% endif %}

              <div class="insta-overlay">
                <span class="secondary-btn">View Post</span>
              </div>

              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_navigation %}
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      {% endif %}

      {% if section.settings.show_pagination %}
        <div class="swiper-pagination"></div>
      {% endif %}

    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function() {
  new Swiper(".instaSwiper", {
    slidesPerView: 3,
    spaceBetween: 16,
    loop: true,
    autoplay: {
      delay: 3000,
      disableOnInteraction: false
    },
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev"
    },
    pagination: {
      el: ".swiper-pagination",
      enabled: false,
      clickable: true
    },
    breakpoints: {
      0: { slidesPerView: 1 },
      768: { slidesPerView: 2 },
      1024: { slidesPerView: 3 }
    }
  });
});
</script>

{% schema %}
{
  "name": "Instagram Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Us On Instagram"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram post link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Instagram Slider"
    }
  ]
}
{% endschema %}