      "id": "hero_title",
      "label": "Hero Title"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "bottom_left_text",
      "label": "Bottom Left Text"
    },
    {
      "type": "text",
      "id": "bottom_right_text",
      "label": "Bottom Right Text"
    },
    {
      "type": "image_picker",
