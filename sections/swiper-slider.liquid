<section class="testimonial-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="testimonial-wrapper">
    <div class="swiper testimonialSwiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.settings.quote != blank %}
            <div class="swiper-slide">
              <div class="testimonial-content">
                <div class="testimonial-quote">“{{ block.settings.quote }}”</div>

                {% if block.settings.author != blank %}
                  <div class="testimonial-author">
                    <span></span>{{ block.settings.author -}}
                    <span></span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="swiper-pagination"></div>
    </div>
  </div>
  {% if section.settings.cross_icon != blank %}
    <div class="testimonial-cross">
      {% for i in (1..section.settings.cross_count) %}
        <span>
          <img src="{{ section.settings.cross_icon | image_url}}" alt="">
        </span>
      {% endfor %}
    </div>
  {% endif %}
</section>
{% stylesheet %}
  .testimonial-section {
    padding: 150px 25px;
    text-align: center;
    width: 100%;
  }
  .testimonial-wrapper {
    max-width: 720px;
    width: 100%;
    margin: 0 auto;
  }
  .testimonial-quote {
    width: 100%;
    margin-bottom: 25px;
    font-size: 24px;
    line-height: 26px;
    font-family: var(--font-WideBlack);
    color: var(--primary-color);
    text-transform: uppercase;
  }
  .testimonial-author {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: row;
    gap: 24px;
    font-size: 24px;
    font-family: var(--font-WideBlack);
    color: var(--primary-color);
    text-transform: uppercase;
  }
  .testimonial-author span {
    width: 24px;
    height: 2px;
    background-color: var(--primary-color);
  }
  .testimonial-cross {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 150px;
  }
  .testimonial-cross img {
    width: 25px;
    animation: rotate 5s linear infinite;
  }
  /* Swiper Pagination */
  .swiper-pagination-bullet {
    background: var(--primary-color);
    opacity: 0.4;
  }

  .swiper-pagination-bullet-active {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .testimonial-section {
      padding: 80px 25px;
    }
    .testimonial-cross {
      margin-top: 70px;
    }
  }
  @media (max-width: 600px) {
    .testimonial-section {
      padding: 50px 25px;
    }
    .testimonial-quote {
      font-size: 16px;
      line-height: 24px;
    }
    .testimonial-author {
      font-size: 16px;
      gap: 10px;
    }
    .testimonial-cross {
      margin-top: 30px;
    }
    .testimonial-cross img {
      width: 16px;
    }
  }
{% endstylesheet %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.testimonialSwiper', {
      loop: true,
      speed: 800,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        enabled: false,
        clickable: true,
      },
    });
  });
</script>
{% schema %}
{
  "name": "Swiper Slider",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f2efe9"
    },
    {
      "type": "image_picker",
      "id": "cross_icon",
      "label": "Cross Icon Image"
    },
    {
      "type": "range",
      "id": "cross_count",
      "label": "Number of Cross Icons",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Swiper Slider"
    }
  ]
}
{% endschema %}