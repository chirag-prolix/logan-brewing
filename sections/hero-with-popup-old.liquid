    {
      "type": "text",
      "id": "no_button_text",
      "label": "No Button",
      "default": "NO THANKS"
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Legal Text"
    },
    {
      "type": "number",
      "id": "discount_percentage",
      "label": "Discount Percentage",
      "default": 25
    }
  ],
  "presets": [
    {
      "name": "Custom Hero With Popup"
    }
  ]
}
{% endschema %}
