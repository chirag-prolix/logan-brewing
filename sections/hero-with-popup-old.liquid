<script>
  function openPopup(){
    document.getElementById("customPopup").style.display="flex";
    createInitialReels();
  }

  function closePopup(){
    document.getElementById("customPopup").style.display="none";
  }

  function createInitialReels(){
    let logo = "{{ 'spin-logo.png' | asset_url }}";
    for(let i=1;i<=3;i++){
      let reel = document.getElementById("reel"+i);
      reel.innerHTML = "";
      for(let j=0;j<8;j++){
        reel.innerHTML += `<div><img src="${logo}"></div>`;
      }
    }
  }

  function startSpin(name, email){
    let logo = "{{ 'spin-logo.png' | asset_url }}";
    let star = "{{ 'cross-red.svg' | asset_url }}";
    let itemHeight = 48;

    let result = Math.floor(Math.random() * 3) + 1;
    let reelsResult = [star, star, star];
    for(let i=0;i<result;i++) reelsResult[i] = logo;
    reelsResult.sort(() => Math.random() - 0.5);

    for(let i=1;i<=3;i++){
      let reel = document.getElementById("reel"+i);
      reel.innerHTML = "";
      for(let j=0;j<10;j++){
        let img = Math.random() > 0.5 ? logo : star;
        reel.innerHTML += `<div><img src="${img}"></div>`;
      }
      reel.innerHTML += `<div><img src="${reelsResult[i-1]}"></div>`;
      let totalItems = reel.children.length;
      reel.style.transition = "none";
      reel.style.transform = "translateY(0px)";
      reel.offsetHeight;
      let move = (totalItems - 1) * itemHeight;
      setTimeout(()=>{
        reel.style.transition = "transform 2.5s ease-out";
        reel.style.transform = `translateY(-${move}px)`;
      }, 0);
    }

    let discount = result * 10; // 10, 20, or 30

    setTimeout(() => {
      // ── Call your real backend ──────────────────────────────
      fetch('/tools/spin/api/spin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ firstName: name, email: email, discount: discount })
      })
      .then(r => r.json())
      .then(data => {
        document.getElementById("formBlock").style.display = "none";
        document.getElementById("winBlock").style.display  = "flex";

        if(data.success) {
          // Real code from Shopify
          document.getElementById("winTitle").innerText =
            "YOU WIN! " + data.discount + "% OFF";
          document.getElementById("couponCode").innerText = data.code;

          // Remember in session so popup doesn't show again
          sessionStorage.setItem('sp_claimed', '1');

        } else if(data.error === 'You have already claimed a discount.') {
          document.getElementById("winTitle").innerText = "Already Claimed!";
          document.getElementById("couponCode").innerText =
            "You already have a discount code. Log in to see it.";

        } else {
          document.getElementById("winTitle").innerText = "Something went wrong";
          document.getElementById("couponCode").innerText = "Please try again later.";
        }
      })
      .catch(err => {
        console.error(err);
        document.getElementById("formBlock").style.display = "none";
        document.getElementById("winBlock").style.display  = "flex";
        document.getElementById("winTitle").innerText = "Error";
        document.getElementById("couponCode").innerText = "Could not connect. Try again.";
      });
      // ────────────────────────────────────────────────────────

    }, 3000);
  }

  function copyCode() {
    let code = document.getElementById("couponCode").innerText;
    navigator.clipboard.writeText(code);
    document.querySelector(".coupon-box .primary-btn").style.display = "none";
    document.getElementById("copiedMsg").style.display = "inline-flex";
  }

  document.addEventListener("DOMContentLoaded", function(){
    // Don't show popup if already claimed this session
    if(sessionStorage.getItem('sp_claimed')) return;

    document.getElementById("spinForm").addEventListener("submit", function(e){
      e.preventDefault();
      let name  = document.getElementById("spinName").value.trim();
      // Fix: your email input also has id="spinName" — change it to "spinEmail"
      let email = document.getElementById("spinEmail").value.trim();
      if(!name || !email){ alert("Please fill in all fields."); return; }
      startSpin(name, email);
    });
  });
</script>

