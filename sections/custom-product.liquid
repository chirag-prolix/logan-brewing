{% schema %}
{
  "name": "t:general.product",
  "settings": [
        {
        "type": "text",
        "id": "size_title",
        "label": "Sizing Title"
        },
        {
        "type": "richtext",
        "id": "size_content",
        "label": "Sizing Content"
        },
        {
        "type": "text",
        "id": "size_btn_text",
        "label": "Sizing Button Text"
        },
        {
        "type": "url",
        "id": "size_btn_link",
        "label": "Sizing Button Link"
        },

        {
        "type": "text",
        "id": "returns_title",
        "label": "Returns Title"
        },
        {
        "type": "richtext",
        "id": "returns_content",
        "label": "Returns Content"
        },
        {
        "type": "text",
        "id": "returns_btn_text",
        "label": "Returns Button Text"
        },
        {
        "type": "url",
        "id": "returns_btn_link",
        "label": "Returns Button Link"
        },

        {
        "type": "text",
        "id": "shipping_title",
        "label": "Shipping Title"
        },
        {
        "type": "richtext",
        "id": "shipping_content",
        "label": "Shipping Content"
        },
        {
        "type": "text",
        "id": "shipping_btn_text",
        "label": "Shipping Button Text"
        },
        {
        "type": "url",
        "id": "shipping_btn_link",
        "label": "Shipping Button Link"
        },
        {
        "type": "text",
        "id": "title",
        "label": "Section Title",
        "default": "Related Products"
        },
        {
        "type": "range",
        "id": "products_limit",
        "label": "Number of Products",
        "min": 2,
        "max": 8,
        "step": 1,
        "default": 4
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}

{% endschema %}
