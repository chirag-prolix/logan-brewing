<section class="details-banner-section">
  <div class="banner-wrapper">
    
    {% if section.settings.banner_image %}
      <img src="{{ section.settings.banner_image | image_url}}" alt="" class="details-banner-img" >
    {% endif %}

    {% if section.settings.overlay_enable %}
      <div class="banner-overlay"></div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="banner-content">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

  </div>
</section>

<style>
.details-banner-section {
  width: 100%;
}

.banner-wrapper {
  position: relative;
  width: 100%;
  height: {{ section.settings.section_height }}px;
  overflow: hidden;
}

.details-banner-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,{{ section.settings.overlay_opacity }});
}

.banner-content {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #fff;
}

.banner-content h2 {
  font-size: 48px;
  margin: 0;
}

@media(max-width: 768px){
  .banner-wrapper {
    height: 400px;
  }
  .banner-content h2 {
    font-size: 28px;
  }
  @media(max-width: 600px){
  .banner-wrapper {
    height: 210px;
  }
  }
</style>

{% schema %}
{
  "name": "Details Banner Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (Desktop)",
      "min": 300,
      "max": 900,
      "step": 50,
      "default": 600
    },
    {
      "type": "checkbox",
      "id": "overlay_enable",
      "label": "Enable Overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 0.9,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text"
    }
  ],
  "presets": [
    {
      "name": "Details Banner Section"
    }
  ]
}
{% endschema %}
