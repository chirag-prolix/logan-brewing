<footer
  class="footer"
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
>
  <div class="page-width">
    <div class="footer-logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.footer_logo != blank %}
          <img src="{{ section.settings.footer_logo | image_url: width: 400 }}" alt="Logan Brewing">
        {% endif %}
      </a>
    </div>

    <div class="footer-grid">
      <div class="ft-menu-main-col">
        {% for block in section.blocks %}
          {% if block.type == 'menu_column' %}
            <div class="footer-column">
              <h4>{{ block.settings.column_title }}</h4>
              {% if block.settings.menu != blank %}
                <ul>
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="ft-fav-logo-col">
        {% if section.settings.footer_fav_logo != blank %}
          <img src="{{ section.settings.footer_fav_logo | image_url: width: 77 }}" alt="Logan Brewing">
        {% endif %}
      </div>

      <div class="ft-newsletter-main-col">
        <div class="footer-column newsletter-column">
          {% if section.settings.newsletter_title != blank %}
            <h4>{{ section.settings.newsletter_title }}</h4>
          {% endif %}

          {% form 'customer' %}
            <input type="text" name="contact[name]" placeholder="NAME*" required>
            {% comment %} <input type="text" name="contact[last_name]" placeholder="Last Name*" required> {% endcomment %}
            <input type="email" name="contact[email]" placeholder="EMAIL*" required>

            <button type="submit" class="signup-btn {{ section.settings.newsletter_btn_class }}">
              {{ section.settings.newsletter_btn_text }}
            </button>
          {% endform %}
        </div>
        <div class="footer-column socials-column">
          {% if section.settings.social_title != blank %}
            <h4>{{ section.settings.social_title }}</h4>
          {% endif %}

          {% if section.settings.social_subtitle != blank %}
            <p class="social-subtitle">
              {{ section.settings.social_subtitle }}
            </p>
          {% endif %}

          <div class="social-icons">
            {% for block in section.blocks %}
              {% if block.type == 'social_item' %}
                <a href="{{ block.settings.social_link }}" target="_blank" class="social-item">
                  {% if block.settings.social_image != blank %}
                    <img src="{{ block.settings.social_image | image_url}}" alt="{{ block.settings.social_name }}">
                  {% else %}
                    <span>{{ block.settings.social_name }}</span>
                  {% endif %}
                </a>
              {% endif %}
            {% endfor %}
          </div>

          {% if section.settings.contact_text != blank %}
            <a href="{{ section.settings.contact_link }}" class="contact-btn primary-btn">
              {{ section.settings.contact_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div>
        © {{ 'now' | date: '%Y' }}
        {{ section.settings.bottom_text }}
      </div>
      <div class="footer-tagline">{{ section.settings.tagline }}</div>
      <div class="footer-right">{{ section.settings.bottom_right_text }}</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "footer_logo", "label": "Footer Logo" },
    { "type": "image_picker", "id": "footer_fav_logo", "label": "Footer Fav Logo" },

    { "type": "text", "id": "newsletter_title", "label": "Newsletter Title", "default": "GET THE LATEST" },
    { "type": "text", "id": "newsletter_btn_text", "label": "Newsletter Button Text", "default": "SIGN UP" },
    { "type": "text", "id": "newsletter_btn_class", "label": "Newsletter Button Class" },

    { "type": "text", "id": "social_title", "label": "Social Section Title", "default": "SOCIALS" },
    { "type": "text", "id": "social_subtitle", "label": "Social Subtitle", "default": "Chuck us a follow" },

    { "type": "text", "id": "contact_text", "label": "Contact Button Text", "default": "CONTACT US" },
    { "type": "url", "id": "contact_link", "label": "Contact Button Link" },

    { "type": "text", "id": "bottom_text", "label": "Bottom Left Text" },
    { "type": "text", "id": "bottom_right_text", "label": "Bottom Right Text" },
    { "type": "text", "id": "tagline", "label": "Bottom Tagline" },

    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#7b1d1d" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        { "type": "text", "id": "column_title", "label": "Column Title" },
        { "type": "link_list", "id": "menu", "label": "Select Menu" }
      ]
    },
    {
      "type": "social_item",
      "name": "Social Icon",
      "settings": [
        {
          "type": "text",
          "id": "social_name",
          "label": "Social Name (Fallback Text)"
        },
        {
          "type": "url",
          "id": "social_link",
          "label": "Social Link"
        },
        {
          "type": "image_picker",
          "id": "social_image",
          "label": "Upload Social Icon Image (Optional)"
        }
      ]
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}